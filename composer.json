{
    "name": "daniardev/laravel-core",
    "description": "Reusable Laravel Core Package - Helpers, Traits, and Patterns for consistent code structure",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "helpers",
        "traits",
        "patterns",
        "reusable"
    ],
    "authors": [
        {
            "name": "DaniarDev",
            "email": "info@daniar.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "DaniarDev\\LaravelCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DaniarDev\\LaravelCore\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DaniarDev\\LaravelCore\\LaravelCoreServiceProvider"
            ],
            "aliases": {
                "AppHelper": "DaniarDev\\LaravelCore\\Helpers\\AppHelper",
                "AppRequest": "DaniarDev\\LaravelCore\\Helpers\\AppRequest",
                "AppResponse": "DaniarDev\\LaravelCore\\Helpers\\AppResponse",
                "AppSafe": "DaniarDev\\LaravelCore\\Helpers\\AppSafe",
                "AppQuery": "DaniarDev\\LaravelCore\\Helpers\\AppQuery",
                "AppResource": "DaniarDev\\LaravelCore\\Helpers\\AppResource",
                "AppMigration": "DaniarDev\\LaravelCore\\Helpers\\AppMigration",
                "AppValidation": "DaniarDev\\LaravelCore\\Helpers\\AppValidation",
                "AppLog": "DaniarDev\\LaravelCore\\Helpers\\AppLog",
                "AppPermission": "DaniarDev\\LaravelCore\\Helpers\\AppPermission",
                "AppSecure": "DaniarDev\\LaravelCore\\Helpers\\AppSecure"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}