{
    "name": "daniardev/laravel-tsd",
    "description": "Laravel TSD Package - Traits, Helpers, and Exceptions for Laravel applications",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "traits", "helpers", "exceptions", "service-layer"],
    "autoload": {
        "psr-4": {
            "Daniardev\\LaravelTsd\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Daniardev\\LaravelTsd\\LaravelTsdServiceProvider",
                "Daniardev\\LaravelTsd\\Providers\\MacroServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "Pujan Daniar",
            "email": "pujan@daniar.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
